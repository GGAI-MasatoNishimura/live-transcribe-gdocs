{
  "manifest_version": 3,
  "name": "Live Transcribe to Google Docs",
  "version": "0.0.7",
  "description": "MVP: Meet 音声を文字起こしし Google ドキュメントへ追記（段階的実装中）。",
  "permissions": ["storage", "tabCapture", "tabs", "activeTab"],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "https://meet.google.com/*"
  ],
  "action": {
    "default_title": "Live Transcribe to Google Docs",
    "default_popup": "popup.html"
  }
}
